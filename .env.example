# Rainforest API
RAINFOREST_API_KEY=

# Zinc API
ZINC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=     # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET= # whsec_...

# Binance Pay (legacy — being replaced by Stripe)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mamazon

# Auth0
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=  # generate with: openssl rand -hex 32
APP_BASE_URL=http://localhost:3000

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin (comma-separated emails)
ADMIN_EMAILS=

# Mock modes (set to "true" to mock external APIs)
ZINC_MOCK=true
BINANCE_MOCK=true
RAINFOREST_MOCK=true
